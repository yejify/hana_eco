datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Activity {
  id           String   @id @default(uuid())
  activityDate String
  productName  String
  activityType String
  amount       Float
  unit         String
  emission     Float
  createdAt    DateTime @default(now())
}